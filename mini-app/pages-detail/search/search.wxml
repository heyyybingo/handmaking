<view class="page">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索作品..."
        value="{{keyword}}"
        bindinput="onInput"
        bindconfirm="onSearch"
        confirm-type="search"
        focus
      />
      <text wx:if="{{keyword}}" class="clear-icon" bindtap="onClearKeyword">✕</text>
    </view>
    <view class="search-btn" bindtap="onSearch">搜索</view>
  </view>

  <!-- 搜索历史 -->
  <view wx:if="{{!searched && history.length > 0}}" class="history-section">
    <view class="section-header">
      <text class="section-title">搜索历史</text>
      <text class="section-action" bindtap="onClearHistory">清空</text>
    </view>
    <view class="history-list">
      <view
        wx:for="{{history}}"
        wx:key="*this"
        class="history-item"
        data-keyword="{{item}}"
        bindtap="onHistoryTap"
      >
        {{item}}
      </view>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view wx:if="{{searched}}" class="result-section">
    <view wx:if="{{loading}}" class="loading-container">
      <skeleton image rows="{{3}}" />
    </view>

    <view wx:elif="{{results.length === 0}}" class="empty-container">
      <empty-state icon="🔍" text="未找到相关作品" subtext="换个关键词试试" />
    </view>

    <view wx:else class="result-list">
      <view
        wx:for="{{results}}"
        wx:key="id"
        class="result-item"
        data-id="{{item.id}}"
        bindtap="onCraftTap"
      >
        <card hover>
          <view class="result-content">
            <image class="result-image" src="{{item.images[0].thumbnailUrl}}" mode="aspectFill" lazy-load />
            <view class="result-info">
              <text class="result-title">{{item.title}}</text>
              <view class="result-meta">
                <tag type="primary" size="small">{{item.category.name}}</tag>
                <text class="result-likes">❤️ {{item.like_count}}</text>
              </view>
            </view>
          </view>
        </card>
      </view>
    </view>
  </view>
</view>
