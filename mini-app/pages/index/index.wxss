@import '../../styles/variables.wxss';

.page {
  min-height: 100vh;
  background-color: @bg-page;
}

/* 分类滚动 */
.category-scroll {
  background-color: @bg-card;
  white-space: nowrap;
  border-bottom: 1rpx solid @divider;
}

.category-list {
  display: inline-flex;
  padding: @spacing-sm @spacing-md;
  gap: @spacing-md;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: @spacing-xs @spacing-sm;
  border-radius: @radius-md;
  transition: all 0.3s ease;
  position: relative;
}

.category-item.active {
  background-color: rgba(196, 149, 106, 0.15);
}

.category-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 4rpx;
  background-color: @primary;
  border-radius: 2rpx;
}

.category-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
  transition: transform 0.3s ease;
}

.category-item.active .category-icon {
  transform: scale(1.15);
}

.category-name {
  font-size: @font-tag;
  color: @text-body;
  transition: color 0.3s ease;
}

.category-item.active .category-name {
  color: @primary;
  font-weight: @weight-medium;
}

/* 加载状态 */
.loading-container {
  padding: @spacing-md;
}

.empty-container {
  padding: 96rpx 0;
}

/* 瀑布流 */
.waterfall {
  display: flex;
  padding: @spacing-sm;
  gap: @spacing-sm;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: @spacing-sm;
}

.waterfall-item {
  break-inside: avoid;
  animation: cardFadeIn 0.4s ease forwards;
  opacity: 0;
}

.waterfall-column:first-child .waterfall-item:nth-child(1) { animation-delay: 0ms; }
.waterfall-column:first-child .waterfall-item:nth-child(2) { animation-delay: 50ms; }
.waterfall-column:first-child .waterfall-item:nth-child(3) { animation-delay: 100ms; }
.waterfall-column:first-child .waterfall-item:nth-child(4) { animation-delay: 150ms; }
.waterfall-column:first-child .waterfall-item:nth-child(5) { animation-delay: 200ms; }
.waterfall-column:first-child .waterfall-item:nth-child(6) { animation-delay: 250ms; }
.waterfall-column:first-child .waterfall-item:nth-child(7) { animation-delay: 300ms; }
.waterfall-column:first-child .waterfall-item:nth-child(8) { animation-delay: 350ms; }

.waterfall-column:last-child .waterfall-item:nth-child(1) { animation-delay: 25ms; }
.waterfall-column:last-child .waterfall-item:nth-child(2) { animation-delay: 75ms; }
.waterfall-column:last-child .waterfall-item:nth-child(3) { animation-delay: 125ms; }
.waterfall-column:last-child .waterfall-item:nth-child(4) { animation-delay: 175ms; }
.waterfall-column:last-child .waterfall-item:nth-child(5) { animation-delay: 225ms; }
.waterfall-column:last-child .waterfall-item:nth-child(6) { animation-delay: 275ms; }
.waterfall-column:last-child .waterfall-item:nth-child(7) { animation-delay: 325ms; }
.waterfall-column:last-child .waterfall-item:nth-child(8) { animation-delay: 375ms; }

@keyframes cardFadeIn {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.craft-image {
  width: 100%;
  border-radius: @radius-md @radius-md 0 0;
  animation: imageFadeIn 0.5s ease forwards;
}

@keyframes imageFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.craft-info {
  padding: @spacing-sm;
}

.craft-title {
  font-size: @font-body;
  font-weight: @weight-medium;
  color: @text-heading;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: @spacing-xs;
}

.craft-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.craft-likes {
  font-size: @font-tag;
  color: @text-secondary;
}
