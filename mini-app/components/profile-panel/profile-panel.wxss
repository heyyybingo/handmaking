@import '../../styles/variables.wxss';

.panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.panel {
  width: 100%;
  background-color: @bg-card;
  border-radius: @radius-lg @radius-lg 0 0;
  padding: @spacing-lg;
  padding-bottom: calc(@spacing-lg + env(safe-area-inset-bottom));
}

.panel-header {
  text-align: center;
  margin-bottom: @spacing-lg;
}

.panel-title {
  font-size: @font-h3;
  font-weight: @weight-bold;
  color: @text-heading;
}

.panel-body {
  margin-bottom: @spacing-lg;
}

.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: @spacing-md;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: @radius-full;
  overflow: hidden;
  padding: 0;
  margin: 0;
  background-color: @secondary-camel;
  line-height: normal;
  border: none;
}

.avatar-btn::after {
  border: none;
}

.avatar-preview {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.avatar-text {
  font-size: @font-tag;
  color: @primary-dark;
}

.nickname-section {
  margin-bottom: @spacing-md;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  background-color: @bg-page;
  border-radius: @radius-md;
  padding: 0 @spacing-md;
  font-size: @font-body;
  color: @text-heading;
  box-sizing: border-box;
}

.panel-footer {
  display: flex;
  gap: @spacing-md;
}

.btn-skip {
  flex: 1;
  height: 88rpx;
  background-color: @bg-page;
  color: @text-body;
  font-size: @font-body;
  border-radius: @radius-md;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: normal;
}

.btn-skip::after {
  border: none;
}

.btn-confirm {
  flex: 1;
  height: 88rpx;
  background-color: @primary;
  color: #FFFFFF;
  font-size: @font-body;
  border-radius: @radius-md;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: normal;
}

.btn-confirm::after {
  border: none;
}
