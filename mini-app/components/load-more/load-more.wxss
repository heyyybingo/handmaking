@import '../../styles/variables.wxss';

.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  gap: 12rpx;
}

.load-more-text {
  font-size: @font-secondary;
  color: @text-secondary;
}

.load-more-error .load-more-text {
  color: @color-error;
}

.load-more-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid @divider;
  border-top-color: @primary;
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
