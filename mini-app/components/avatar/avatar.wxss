@import '../../styles/variables.wxss';

.avatar {
  border-radius: @radius-full;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-default {
  width: 100%;
  height: 100%;
  background-color: @secondary-camel;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 0.5em;
  color: @primary-dark;
}
