@import '../../styles/variables.wxss';

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 96rpx 32rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: @font-body;
  color: @text-body;
  margin-bottom: 8rpx;
}

.empty-subtext {
  font-size: @font-secondary;
  color: @text-secondary;
}
