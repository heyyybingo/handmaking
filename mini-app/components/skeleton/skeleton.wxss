@import '../../styles/variables.wxss';

.skeleton {
  padding: @card-padding;
}

.skeleton-image {
  width: 100%;
  height: 300rpx;
  border-radius: @radius-md;
  margin-bottom: @spacing-md;
}

.skeleton-content {
  display: flex;
  gap: @spacing-sm;
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: @radius-full;
  flex-shrink: 0;
}

.skeleton-lines {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: @spacing-sm;
}

.skeleton-line {
  height: 28rpx;
  border-radius: @radius-sm;
}

.skeleton-pulse {
  background: linear-gradient(90deg, @secondary-camel 25%, rgba(232, 213, 192, 0.5) 50%, @secondary-camel 75%);
  background-size: 200% 100%;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}
