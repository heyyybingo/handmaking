@import '../../styles/variables.wxss';

.panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
  animation: maskFadeIn 0.3s ease forwards;
}

@keyframes maskFadeIn {
  to {
    background-color: rgba(0, 0, 0, 0.5);
  }
}

.panel {
  width: 100%;
  background-color: @bg-card;
  border-radius: @radius-lg @radius-lg 0 0;
  padding: @spacing-lg;
  padding-bottom: calc(@spacing-lg + env(safe-area-inset-bottom));
  animation: panelSlideIn 0.3s ease-out forwards;
}

@keyframes panelSlideIn {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: @spacing-lg;
}

.panel-title {
  font-size: @font-h3;
  font-weight: @weight-bold;
  color: @text-heading;
}

.panel-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: @font-h3;
  color: @text-secondary;
}

.panel-body {
  margin-bottom: @spacing-lg;
}

/* 类型选择 */
.type-list {
  display: flex;
  flex-direction: column;
  gap: @spacing-sm;
  margin-bottom: @spacing-lg;
}

.type-item {
  padding: @spacing-md;
  background-color: @bg-page;
  border-radius: @radius-md;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.type-item.selected {
  background-color: rgba(196, 149, 106, 0.1);
  border-color: @primary;
  animation: borderFadeIn 0.3s ease forwards;
}

@keyframes borderFadeIn {
  from {
    border-color: transparent;
    box-shadow: 0 0 0 0 rgba(196, 149, 106, 0);
  }
  to {
    border-color: @primary;
    box-shadow: 0 0 0 4rpx rgba(196, 149, 106, 0.1);
  }
}

.type-label {
  font-size: @font-body;
  font-weight: @weight-medium;
  color: @text-heading;
  display: block;
  margin-bottom: 4rpx;
}

.type-desc {
  font-size: @font-secondary;
  color: @text-secondary;
}

/* 留言输入 */
.message-section {
  position: relative;
}

.message-input {
  width: 100%;
  height: 200rpx;
  background-color: @bg-page;
  border-radius: @radius-md;
  padding: @spacing-md;
  font-size: @font-body;
  color: @text-heading;
  box-sizing: border-box;
}

.message-count {
  position: absolute;
  bottom: @spacing-sm;
  right: @spacing-md;
  font-size: @font-tag;
  color: @text-secondary;
}

/* 提交按钮 */
.panel-footer {
  margin-top: @spacing-md;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  background-color: @primary;
  color: #FFFFFF;
  font-size: @font-body;
  border-radius: @radius-md;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: normal;
  transition: all 0.3s ease;
}

.btn-submit::after {
  border: none;
}

.btn-submit:active:not([disabled]) {
  transform: scale(0.98);
}

.btn-submit[disabled] {
  background-color: @divider;
  color: @text-secondary;
}

.btn-submit.loading {
  position: relative;
  pointer-events: none;
}

.btn-submit.loading::before {
  content: '';
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: @spacing-sm;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
