# ============================================================
# 手作展示平台 - 环境变量模板
# 使用方式：cp deploy/.env.example .env.dev，然后填入实际值
# ============================================================

# ==================== 应用配置 ====================
NODE_ENV=development
APP_PORT=3000

# ==================== 数据库配置（PostgreSQL） ====================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=handcraft
DATABASE_USER=handcraft
DATABASE_PASSWORD=handcraft-dev

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=handcraft-dev-redis

# ==================== 存储服务配置 ====================
# 存储提供者：minio（开发阶段） / oss（生产阶段）
STORAGE_PROVIDER=minio

# MinIO 配置（开发阶段使用）
MINIO_ENDPOINT=localhost
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=handcraft-dev
MINIO_SECRET_KEY=handcraft-dev-secret
MINIO_BUCKET=handcraft
# MinIO 是否使用 HTTPS（本地开发通常为 false）
MINIO_USE_SSL=false

# OSS 配置（生产阶段使用，开发阶段可留空）
OSS_ENDPOINT=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=
OSS_REGION=
CDN_DOMAIN=

# ==================== 微信小程序配置 ====================
WX_APPID=your_wx_appid
WX_SECRET=your_wx_secret

# ==================== AI 服务配置 ====================
AI_MODEL=gpt-4o-mini
AI_API_KEY=your_ai_api_key
AI_BASE_URL=https://api.openai.com/v1

# ==================== JWT 配置 ====================
JWT_SECRET=your_jwt_secret_change_in_production
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ==================== 管理员配置 ====================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production
